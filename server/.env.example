PAYPAL_MODE=sandbox   # sandbox | live

# ─── Email (Gmail SMTP) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=tu_app_password_aqui
